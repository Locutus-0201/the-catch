datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RegattaTier {
  SA_CHAMPS
  NATIONAL
  REGIONAL
  CLUB
}

enum RegattaStatus {
  UPCOMING
  DRAW_PUBLISHED
  RACING
  RESULTS_FINAL
  ARCHIVED
}

model Season {
  id        String    @id @default(cuid())
  year      Int       @unique
  label     String
  createdAt DateTime  @default(now())
  regattas  Regatta[]
  rowerSchoolHistories RowerSchoolHistory[]
}

model Regatta {
  id          String        @id @default(cuid())
  name        String
  sourceUrl   String        @unique
  seasonId    String
  season      Season        @relation(fields: [seasonId], references: [id])
  tier        RegattaTier   @default(REGIONAL)
  status      RegattaStatus @default(UPCOMING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  events      Event[]
  weatherLogs WeatherLog[]
  scraperLogs ScraperLog[]
}

enum RaceType {
  HEAT
  SEMIFINAL
  FINAL_A
  FINAL_B
  FINAL_C
}

enum RaceStatus {
  DRAW
  COMPLETE
}

enum ResultStatus {
  FINISHED
  DNS
  DNF
  DSQ
}

model Event {
  id        String   @id @default(cuid())
  regattaId String
  regatta   Regatta  @relation(fields: [regattaId], references: [id], onDelete: Cascade)
  name      String
  ageGroup  String
  boatClass String
  gender    String
  sourceUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  races     Race[]

  @@unique([regattaId, name])
}

model Race {
  id         String     @id @default(cuid())
  eventId    String
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  raceType   RaceType
  heatNumber Int?
  status     RaceStatus @default(DRAW)
  sourceUrl  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  results    Result[]
}

model Result {
  id             String        @id @default(cuid())
  raceId         String
  race           Race          @relation(fields: [raceId], references: [id], onDelete: Cascade)
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id])
  lane           Int?
  placement      Int?
  finishTimeMs   Int?
  resultStatus   ResultStatus  @default(FINISHED)
  points         Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  crewMembers    ResultRower[]
  personalBests  PersonalBest[]

  @@unique([raceId, schoolId])
}

model ResultRower {
  id         String @id @default(cuid())
  resultId   String
  result     Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
  rowerId    String
  rower      Rower  @relation(fields: [rowerId], references: [id])
  seatNumber Int?
}

model School {
  id              String          @id @default(cuid())
  name            String          @unique
  shortName       String?
  isMasters       Boolean         @default(false)
  isUniversity    Boolean         @default(false)
  createdAt       DateTime        @default(now())
  aliases         SchoolAlias[]
  rowers          Rower[]
  results         Result[]
  rivalriesAsA    SchoolRivalry[] @relation("SchoolA")
  rivalriesAsB    SchoolRivalry[] @relation("SchoolB")
  rowerSchoolHistories RowerSchoolHistory[]
}

model SchoolAlias {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  alias    String @unique
}

model SchoolRivalry {
  id          String   @id @default(cuid())
  schoolAId   String
  schoolBId   String
  schoolA     School   @relation("SchoolA", fields: [schoolAId], references: [id])
  schoolB     School   @relation("SchoolB", fields: [schoolBId], references: [id])
  winsA       Int      @default(0)
  winsB       Int      @default(0)
  draws       Int      @default(0)
  totalRaces  Int      @default(0)
  lastUpdated DateTime @updatedAt

  @@unique([schoolAId, schoolBId])
}
